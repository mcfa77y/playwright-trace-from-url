{
	"name": "playwright-trace-from-url",
	"version": "1.0.0",
	"description": "A beautiful CLI/TUI to download and view Playwright trace artifacts from GitHub Actions.",
	"module": "src/index.ts",
	"type": "module",
	"scripts": {
		"start": "bun src/index.ts",
		"test": "bun test",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"prepare": "husky"
	},
	"dependencies": {
		"@inquirer/prompts": "^8.4.3",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"conf": "^15.1.0",
		"figlet": "^1.11.0",
		"ora": "^9.4.0",
		"unzipper": "^0.12.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/figlet": "^1.7.0",
		"@types/node": "^25.9.1",
		"@types/unzipper": "^0.10.11",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"typescript": "^5.0.0"
	},
	"lint-staged": {
		"*.{ts,js,json}": [
			"biome check --write"
		]
	}
}
